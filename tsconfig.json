{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".build",
    "rootDir": ".",
    "types": ["node"],
    "allowImportingTsExtensions": true
  },
  "include": ["netlify/**/*.mts", "src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", ".build"]
}